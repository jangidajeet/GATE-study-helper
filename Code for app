<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ajeet GATE EE Pro</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg: #0b0f19;
            --card: #161e2d;
            --accent: #38bdf8;
            --text: #e2e8f0;
            --success: #10b981;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'Inter', sans-serif;
            margin: 0; padding: 20px;
        }

        .ajeet-brand {
            position: fixed; font-weight: 900; font-size: 14px;
            color: rgba(56, 189, 248, 0.1); text-transform: uppercase;
            z-index: -1; pointer-events: none;
        }
        .tl { top: 15px; left: 15px; } .tr { top: 15px; right: 15px; }
        .bl { bottom: 15px; left: 15px; } .br { bottom: 15px; right: 15px; }

        .container { max-width: 900px; margin: auto; }

        /* Daily Goal Dashboard */
        .dashboard {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--card);
            padding: 20px;
            border-radius: 15px;
            text-align: center;
            border: 1px solid #334155;
        }

        .goal-progress {
            font-size: 2rem;
            font-weight: bold;
            color: var(--success);
        }

        .subject-card {
            background: var(--card);
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            border-left: 4px solid var(--accent);
        }

        .grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 10px; }
        
        input[type="number"], input[type="text"] {
            background: #0b0f19; border: 1px solid #475569; color: white;
            padding: 8px; border-radius: 5px; width: 70%;
        }

        button {
            background: var(--accent); color: #0b0f19; border: none;
            padding: 10px 15px; border-radius: 6px; cursor: pointer; font-weight: bold;
        }

        .reset-btn { background: #475569; color: white; margin-top: 10px; font-size: 11px; }
    </style>
</head>
<body>

    <div class="ajeet-brand tl">Ajeet</div><div class="ajeet-brand tr">Ajeet</div>
    <div class="ajeet-brand bl">Ajeet</div><div class="ajeet-brand br">Ajeet</div>

    <div class="container">
        <header style="text-align:center; margin-bottom:20px;">
            <h1>GATE EE: <span id="display-name">Ajeet</span></h1>
        </header>

        <div class="dashboard">
            <div class="stat-card">
                <small>DAYS TO GATE</small>
                <div id="days-left" style="font-size: 2rem; color: var(--accent); font-weight:bold;">--</div>
            </div>
            <div class="stat-card">
                <small>DAILY GOAL PROGRESS</small>
                <div class="goal-progress"><span id="daily-count">0</span> / <span id="target-display">10</span></div>
                <input type="number" id="goal-setter" style="width:40px" placeholder="Set" onchange="updateGoal(this.value)">
                <br><button class="reset-btn" onclick="resetDaily()">Reset Daily Count</button>
            </div>
        </div>

        <div class="stat-card" style="margin-bottom:20px;">
            <canvas id="progressChart" height="100"></canvas>
        </div>

        <div id="subject-container"></div>
        
        <div class="stat-card">
            <h3>Add New Subject</h3>
            <input type="text" id="new-sub" placeholder="Subject Name">
            <button onclick="addSubject()">Add</button>
        </div>
    </div>

    <script>
        let db = JSON.parse(localStorage.getItem('ajeetGateDataV2')) || {
            userName: "Ajeet",
            examDate: "2027-02-14",
            dailyTarget: 10,
            dailyDone: 0,
            subjects: {
                "Network Analysis": {Notes:0, Revision:0, DPP:0, PYQs:0, Mock:0},
                "Power Systems": {Notes:0, Revision:0, DPP:0, PYQs:0, Mock:0},
                "Electrical Machines": {Notes:0, Revision:0, DPP:0, PYQs:0, Mock:0}
            }
        };

        function init() {
            document.getElementById('display-name').innerText = db.userName;
            document.getElementById('target-display').innerText = db.dailyTarget;
            document.getElementById('daily-count').innerText = db.dailyDone;
            renderCountdown();
            renderSubjects();
            renderChart();
        }

        function updateVal(sub, key, val) {
            let diff = parseInt(val) - db.subjects[sub][key];
            if (diff > 0) db.dailyDone += diff; // Add to daily progress if value increases
            db.subjects[sub][key] = parseInt(val) || 0;
            save();
        }

        function updateGoal(val) {
            db.dailyTarget = parseInt(val);
            save();
            init();
        }

        function resetDaily() {
            db.dailyDone = 0;
            save();
            init();
        }

        function renderCountdown() {
            const days = Math.ceil((new Date(db.examDate) - new Date()) / (1000 * 60 * 60 * 24));
            document.getElementById('days-left').innerText = days;
        }

        function renderSubjects() {
            const container = document.getElementById('subject-container');
            container.innerHTML = '';
            for (const sub in db.subjects) {
                const card = document.createElement('div');
                card.className = 'subject-card';
                card.innerHTML = `
                    <h3>${sub}</h3>
                    <div class="grid">
                        <div>Notes<br><input type="number" value="${db.subjects[sub].Notes}" onchange="updateVal('${sub}','Notes',this.value)"></div>
                        <div>Revision<br><input type="number" value="${db.subjects[sub].Revision}" onchange="updateVal('${sub}','Revision',this.value)"></div>
                        <div>DPP<br><input type="number" value="${db.subjects[sub].DPP}" onchange="updateVal('${sub}','DPP',this.value)"></div>
                        <div>PYQs<br><input type="number" value="${db.subjects[sub].PYQs}" onchange="updateVal('${sub}','PYQs',this.value)"></div>
                        <div style="color:var(--accent)">Mock<br><input type="number" value="${db.subjects[sub].Mock}" onchange="updateVal('${sub}','Mock',this.value)"></div>
                    </div>
                `;
                container.appendChild(card);
            }
        }

        function addSubject() {
            const name = document.getElementById('new-sub').value;
            if(name) {
                db.subjects[name] = {Notes:0, Revision:0, DPP:0, PYQs:0, Mock:0};
                save(); renderSubjects();
            }
        }

        function save() {
            localStorage.setItem('ajeetGateDataV2', JSON.stringify(db));
            document.getElementById('daily-count').innerText = db.dailyDone;
            renderChart();
        }

        function renderChart() {
            const ctx = document.getElementById('progressChart').getContext('2d');
            const labels = Object.keys(db.subjects);
            const data = labels.map(s => db.subjects[s].Notes + db.subjects[s].Revision + db.subjects[s].DPP + db.subjects[s].PYQs);
            if(window.chartObj) window.chartObj.destroy();
            window.chartObj = new Chart(ctx, {
                type: 'bar',
                data: { labels: labels, datasets: [{ label: 'Total Progress', data: data, backgroundColor: '#38bdf8' }] },
                options: { responsive: true, scales: { y: { beginAtZero: true } } }
            });
        }

        init();
    </script>
</body>
</html>
