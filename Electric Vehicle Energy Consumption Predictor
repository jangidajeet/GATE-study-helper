        "import streamlit as st\n",
        "import pandas as pd\n",
        "import pickle\n",
        "import random\n",
        "import os\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# PAGE CONFIG\n",
        "# ===============================\n",
        "\n",
        "st.set_page_config(\n",
        "    page_title=\"AI EV Driving Optimizer\",\n",
        "    page_icon=\"🚗\",\n",
        "    layout=\"wide\"\n",
        ")\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# LOAD MODEL\n",
        "# ===============================\n",
        "\n",
        "@st.cache_resource\n",
        "def load_model():\n",
        "\n",
        "    return pickle.load(\n",
        "        open(\"model.pkl\",\"rb\")\n",
        "    )\n",
        "\n",
        "\n",
        "model = load_model()\n",
        "\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# HISTORY STORAGE\n",
        "# ===============================\n",
        "\n",
        "history_file=\"driving_history.csv\"\n",
        "\n",
        "\n",
        "\n",
        "def save_history(data):\n",
        "\n",
        "    new=pd.DataFrame([data])\n",
        "\n",
        "    if os.path.exists(history_file):\n",
        "\n",
        "        old=pd.read_csv(history_file)\n",
        "\n",
        "        new=pd.concat(\n",
        "            [old,new],\n",
        "            ignore_index=True\n",
        "        )\n",
        "\n",
        "\n",
        "    new.to_csv(\n",
        "        history_file,\n",
        "        index=False\n",
        "    )\n",
        "\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# FUNCTIONS\n",
        "# ===============================\n",
        "\n",
        "\n",
        "def efficiency_score(speed,accel,traffic,slope):\n",
        "\n",
        "    score=100\n",
        "\n",
        "\n",
        "    if speed>90:\n",
        "        score-=20\n",
        "\n",
        "    elif speed>70:\n",
        "        score-=10\n",
        "\n",
        "\n",
        "    if abs(accel)>2:\n",
        "        score-=20\n",
        "\n",
        "\n",
        "    if traffic==3:\n",
        "        score-=15\n",
        "\n",
        "\n",
        "    if slope>5:\n",
        "        score-=10\n",
        "\n",
        "\n",
        "    return max(score,0)\n",
        "\n",
        "\n",
        "\n",
        "def health_score(battery,temp,tire):\n",
        "\n",
        "    score=100\n",
        "\n",
        "\n",
        "    if battery<30:\n",
        "        score-=25\n",
        "\n",
        "\n",
        "    if temp>40:\n",
        "        score-=30\n",
        "\n",
        "\n",
        "    if tire<30:\n",
        "        score-=20\n",
        "\n",
        "\n",
        "    return max(score,0)\n",
        "\n",
        "\n",
        "\n",
        "def driving_style(speed,accel):\n",
        "\n",
        "    if speed>90 and accel>2:\n",
        "        return \"🚨 Aggressive Driver\"\n",
        "\n",
        "    elif speed<70 and abs(accel)<1:\n",
        "        return \"🌱 Eco Driver\"\n",
        "\n",
        "    else:\n",
        "        return \"⚡ Normal Driver\"\n",
        "\n",
        "\n",
        "\n",
        "def warnings(speed,battery,temp,accel):\n",
        "\n",
        "    w=[]\n",
        "\n",
        "\n",
        "    if speed>100:\n",
        "        w.append(\n",
        "            \"🚨 High speed reduces EV range\"\n",
        "        )\n",
        "\n",
        "\n",
        "    if battery<25:\n",
        "        w.append(\n",
        "            \"🔋 Battery level is critical\"\n",
        "        )\n",
        "\n",
        "\n",
        "    if temp>40:\n",
        "        w.append(\n",
        "            \"🔥 Battery overheating risk\"\n",
        "        )\n",
        "\n",
        "\n",
        "    if abs(accel)>2:\n",
        "        w.append(\n",
        "            \"⚡ Aggressive acceleration detected\"\n",
        "        )\n",
        "\n",
        "\n",
        "    if not w:\n",
        "        w.append(\n",
        "            \"✅ Vehicle condition is healthy\"\n",
        "        )\n",
        "\n",
        "\n",
        "    return w\n",
        "\n",
        "\n",
        "\n",
        "def advice(score):\n",
        "\n",
        "    if score>=85:\n",
        "\n",
        "        return \"\"\"\n",
        "🌱 Eco Driving Song:\n",
        "\n",
        "Smooth on the pedal, gentle and bright,\n",
        "Save your battery day and night.\n",
        "Keep your speed calm, your driving smart,\n",
        "More electric miles is the art.\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "    elif score>=70:\n",
        "\n",
        "        return \"\"\"\n",
        "⚡ Smart Driving Tune:\n",
        "\n",
        "Balance your speed and control your way,\n",
        "More range will come at the end of the day.\n",
        "Drive with care, avoid the strain,\n",
        "Your EV rewards with extra range.\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "    else:\n",
        "\n",
        "        return \"\"\"\n",
        "🚨 Energy Saving Reminder:\n",
        "\n",
        "Fast acceleration and speed too high,\n",
        "Make your battery level fly.\n",
        "Slow it down and drive with care,\n",
        "Your EV will travel much more distance there.\n",
        "\"\"\"\n",
        "\n",
        "\n",
        "\n",
        "def random_case():\n",
        "\n",
        "    case=random.choice(\n",
        "        [\n",
        "            \"Eco 🌱\",\n",
        "            \"Normal ⚡\",\n",
        "            \"Extreme 🚨\"\n",
        "        ]\n",
        "    )\n",
        "\n",
        "\n",
        "    if case==\"Eco 🌱\":\n",
        "\n",
        "        return {\n",
        "        \"speed\":55,\n",
        "        \"accel\":0.5,\n",
        "        \"battery\":90,\n",
        "        \"temp\":25,\n",
        "        \"traffic\":1,\n",
        "        \"slope\":0\n",
        "        }\n",
        "\n",
        "\n",
        "    elif case==\"Normal ⚡\":\n",
        "\n",
        "        return {\n",
        "        \"speed\":75,\n",
        "        \"accel\":1.2,\n",
        "        \"battery\":60,\n",
        "        \"temp\":32,\n",
        "        \"traffic\":2,\n",
        "        \"slope\":3\n",
        "        }\n",
        "\n",
        "\n",
        "    else:\n",
        "\n",
        "        return {\n",
        "        \"speed\":115,\n",
        "        \"accel\":2.8,\n",
        "        \"battery\":25,\n",
        "        \"temp\":44,\n",
        "        \"traffic\":3,\n",
        "        \"slope\":8\n",
        "        }\n",
        "\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# TITLE\n",
        "# ===============================\n",
        "\n",
        "\n",
        "st.title(\n",
        "\"🚗 AI Powered EV Driving Efficiency Optimizer\"\n",
        ")\n",
        "\n",
        "\n",
        "st.caption(\n",
        "\"Machine Learning based EV energy prediction and intelligent driving assistant\"\n",
        ")\n",
        "\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# RANDOM BUTTON\n",
        "# ===============================\n",
        "\n",
        "\n",
        "if \"random\" not in st.session_state:\n",
        "\n",
        "    st.session_state.random=None\n",
        "\n",
        "\n",
        "\n",
        "if st.button(\n",
        "\"🎲 Generate Random Driving Condition\"\n",
        "):\n",
        "\n",
        "    st.session_state.random=random_case()\n",
        "\n",
        "\n",
        "\n",
        "# ===============================\n",
        "# INPUT VALUES\n",
        "# ===============================\n",
        "\n",
        "\n",
        "r=st.session_state.random\n",
        "\n",
        "\n",
        "\n",
        "col1,col2,col3,col4=st.columns(4)\n",
        "\n",
        "\n",
        "with col1:\n",
        "\n",
        "    speed=st.slider(\n",
        "        \"Speed km/h\",\n",
        "        0,120,\n",
        "        r[\"speed\"] if r else 60\n",
        "    )\n",
        "\n",
        "\n",
        "with col2:\n",
        "\n",
        "    accel=st.slider(\n",
        "        \"Acceleration\",\n",
        "        -3.0,3.0,\n",
        "        r[\"accel\"] if r else 0.0\n",
        "    )\n",
        "\n",
        "\n",
        "with col3:\n",
        "\n",
        "    battery=st.slider(\n",
        "        \"Battery %\",\n",
        "        20,100,\n",
        "        r[\"battery\"] if r else 80\n",
        "    )\n",
        "\n",
        "\n",
        "with col4:\n",
        "\n",
        "    temp=st.slider(\n",
        "        \"Battery Temp °C\",\n",
        "        10,45,\n",
        "        r[\"temp\"] if r else 30\n",
        "    )\n",
        "\n",
        "\n",
        "\n",
        "col5,col6,col7=st.columns(3)\n",
        "\n",
        "\n",
        "with col5:\n",
        "\n",
        "    traffic=st.selectbox(\n",
        "        \"Traffic\",\n",
        "        [1,2,3],\n",
        "        index=(r[\"traffic\"]-1) if r else 1\n",
        "    )\n",
        "\n",
        "\n",
        "with col6:\n",
        "\n",
        "    slope=st.slider(\n",
        "        \"Slope %\",\n",
        "        -5,10,\n",
        "        r[\"slope\"] if r else 0\n",
        "    )\n",
        "\n",
        "\n",
        "with col7:\n",
        "\n",
        "    distance=st.slider(\n",
