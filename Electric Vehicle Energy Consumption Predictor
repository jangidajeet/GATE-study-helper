        "def efficiency_score(speed, accel, traffic, slope):\n",
        "\n",
        "    score = 100\n",
        "\n",
        "    if speed > 90:\n",
        "        score -= 20\n",
        "\n",
        "    elif speed > 70:\n",
        "        score -= 10\n",
        "\n",
        "    if abs(accel) > 2:\n",
        "        score -= 20\n",
        "\n",
        "    if traffic == 3:\n",
        "        score -= 15\n",
        "\n",
        "    if slope > 5:\n",
        "        score -= 10\n",
        "\n",
        "    return max(score, 0)"
